# Redis connection
REDIS_URL=redis://localhost:6379/0

# TTL for stored JSON objects (seconds)
REDIS_TTL=86400

# Optional prefix for all Redis keys; leave empty to disable
# REDIS_PREFIX=dev

# URL of external preview service used by resolve_continue_url


# RETURNURL_REGEX Regular expression to validate return URLs for security
# RETURNURL_REGEX=^https://example.com/
RETURNURL_REGEX=.*
